{
  "description": "Comprehensive SQLScript code quality validation hooks for SAP HANA development",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/validator.mjs"],
            "timeout": 45
          }
        ]
      }
    ]
  }
}
