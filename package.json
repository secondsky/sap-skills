{
  "name": "sap-skills-validation",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "oracle": "oracle --browser-archive never",
    "oracle:login": "oracle --engine browser --browser-archive never --browser-manual-login --browser-keep-browser --browser-input-timeout 120000 -p \"HI\"",
    "oracle:review": "oracle --engine browser --browser-archive never --files-report",
    "oracle:status": "oracle status --hours 72",
    "oracle:mcp": "oracle-mcp",
    "validate": "./scripts/validate-json-schemas.sh && npm run validate:codex && ./scripts/validate-frontmatter.sh --quiet && ./scripts/validate-reserved-words.sh && ./scripts/validate-bundled-resources.mjs && ./scripts/validate-command-agent-frontmatter.mjs && ./scripts/validate-inventory.sh && ./scripts/validate-manifest-drift.mjs && ./scripts/validate-mcp-security.mjs && ./scripts/validate-mcp-env-contracts.mjs && ./scripts/validate-verification-ledger.mjs && ./scripts/validate-packaging-hygiene.mjs && ./scripts/validate-harness-portability.mjs && ./scripts/validate-public-claims.mjs && ./scripts/validate-oracle-browser-safety.mjs && ./scripts/validate-reference-provenance.mjs && ./scripts/validate-templates.mjs && ./scripts/validate-command-contracts.mjs && ./scripts/validate-agent-contracts.mjs && ./scripts/validate-skill-quality.mjs && ./scripts/audit-effectiveness.mjs --validate && npm run test:lsp-launcher && npm run test:hooks && npm run test:hook-contracts",
    "validate:marketplace": "ajv validate -s schemas/marketplace.schema.json -d .claude-plugin/marketplace.json --strict=false -c ajv-formats --all-errors",
    "validate:plugins": "./scripts/validate-json-schemas.sh",
    "generate:codex": "node ./scripts/generate-codex-layer.mjs",
    "validate:codex": "node ./scripts/validate-codex-layer.mjs",
    "validate:skill-frontmatter": "./scripts/validate-frontmatter.sh --quiet",
    "validate:resources": "./scripts/validate-bundled-resources.mjs",
    "validate:frontmatter-extra": "./scripts/validate-command-agent-frontmatter.mjs",
    "validate:inventory": "./scripts/validate-inventory.sh",
    "validate:mcp-security": "./scripts/validate-mcp-security.mjs",
    "validate:mcp-env-contracts": "./scripts/validate-mcp-env-contracts.mjs",
    "validate:verification-ledger": "./scripts/validate-verification-ledger.mjs",
    "validate:packaging-hygiene": "./scripts/validate-packaging-hygiene.mjs",
    "validate:harness-portability": "./scripts/validate-harness-portability.mjs",
    "validate:public-claims": "./scripts/validate-public-claims.mjs",
    "validate:oracle-browser-safety": "./scripts/validate-oracle-browser-safety.mjs",
    "validate:reference-provenance": "./scripts/validate-reference-provenance.mjs",
    "validate:templates": "./scripts/validate-templates.mjs",
    "validate:command-contracts": "./scripts/validate-command-contracts.mjs",
    "validate:agent-contracts": "./scripts/validate-agent-contracts.mjs",
    "validate:skill-quality": "./scripts/validate-skill-quality.mjs",
    "audit:skills": "./scripts/audit-skills.mjs",
    "audit:effectiveness": "./scripts/audit-effectiveness.mjs",
    "audit:effectiveness:json": "./scripts/audit-effectiveness.mjs --json",
    "audit:mcp-freshness": "./scripts/audit-mcp-freshness.mjs",
    "validate:effectiveness": "./scripts/audit-effectiveness.mjs --validate",
    "test:hooks": "node ./scripts/test-hooks.mjs",
    "test:lsp-launcher": "node ./scripts/test-lsp-launcher.mjs",
    "test:hook-contracts": "node ./scripts/test-hook-contracts.mjs",
    "test:codex": "node ./tests/codex-layer.test.mjs",
    "validate:manifest-drift": "./scripts/validate-manifest-drift.mjs",
    "smoke:local-fixtures": "./scripts/smoke-local-fixtures.mjs"
  },
  "devDependencies": {
    "@steipete/oracle": "0.14.0",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.1"
  }
}
