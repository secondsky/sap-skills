#!/usr/bin/env bash
#
# Pre-commit hook for SAP Skills repository
#
# Validates JSON files (marketplace.json and plugin.json) before commit
# Only validates CHANGED files for performance
#
# Setup (one-time):
#   npm install -g ajv-cli ajv-formats
#   git config core.hooksPath .githooks
#
# Bypass (when necessary):
#   git commit --no-verify

set -e

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCHEMAS_DIR="$REPO_ROOT/schemas"

echo ""
echo "Pre-commit: Checking JSON schemas..."
echo ""

if ! command -v ajv &> /dev/null; then
    echo -e "${YELLOW}ajv-cli not installed. Install with: npm install -g ajv-cli ajv-formats${NC}"
    echo -e "${YELLOW}Skipping JSON validation (will be caught by CI)${NC}"
    exit 0
fi

CHANGED_JSON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.json$' || true)

if [ -z "$CHANGED_JSON_FILES" ]; then
    echo -e "${GREEN}No JSON files changed, skipping validation${NC}"
    exit 0
fi

echo "Changed JSON files:"
echo "$CHANGED_JSON_FILES" | sed 's/^/  - /'
echo ""

VALIDATION_FAILED=0

if echo "$CHANGED_JSON_FILES" | grep -q "\.claude-plugin/marketplace\.json"; then
    echo "Validating marketplace.json..."
    if ajv validate \
        -s "$SCHEMAS_DIR/marketplace.schema.json" \
        -d "$REPO_ROOT/.claude-plugin/marketplace.json" \
        --spec=draft7 \
        --strict=false \
        -c ajv-formats \
        --all-errors; then
        echo -e "${GREEN}marketplace.json is valid${NC}"
    else
        echo -e "${RED}marketplace.json validation failed${NC}"
        VALIDATION_FAILED=1
    fi
    echo ""
fi

CHANGED_PLUGIN_JSON=$(echo "$CHANGED_JSON_FILES" | grep "plugin\.json" | grep -v "marketplace\.json" || true)

if [ -n "$CHANGED_PLUGIN_JSON" ]; then
    echo "Validating plugin.json files..."
    while IFS= read -r plugin_json; do
        PLUGIN_NAME=$(basename "$(dirname "$(dirname "$plugin_json")")")
        echo -n "  $PLUGIN_NAME... "

        set +e
        validation_output=$(ajv validate \
            -s "$SCHEMAS_DIR/plugin.schema.json" \
            -d "$REPO_ROOT/$plugin_json" \
            --spec=draft7 \
            --strict=false \
            -c ajv-formats \
            --all-errors 2>&1)
        validation_exit=$?
        set -e

        if [ $validation_exit -eq 0 ]; then
            echo -e "${GREEN}OK${NC}"
        else
            echo -e "${RED}FAIL${NC}"
            echo "$validation_output"
            VALIDATION_FAILED=1
        fi
    done <<< "$CHANGED_PLUGIN_JSON"
    echo ""
fi

if [ $VALIDATION_FAILED -eq 1 ]; then
    echo -e "${RED}Pre-commit validation failed${NC}"
    echo ""
    echo "Fix the errors above, or bypass with: git commit --no-verify"
    echo "(CI will still catch these errors even if you bypass)"
    echo ""
    exit 1
else
    echo -e "${GREEN}All validations passed${NC}"
    echo ""
    exit 0
fi
